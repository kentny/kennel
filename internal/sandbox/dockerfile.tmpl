# Generated by kennel {{.Version}} — do not edit by hand.
# Source of truth: {{.ConfigPath}}
ARG BASE_IMAGE={{.BaseImage}}
FROM ${BASE_IMAGE}

ARG AGENT={{.Agent}}
ARG INSTALL_PLUGINS={{.InstallPlugins}}

USER root
{{ if .AptPackages -}}

# apt packages from kennel config
RUN apt-get update && apt-get install -y \
{{- range .AptPackages }}
    {{ . }} \
{{- end }}
    && rm -rf /var/lib/apt/lists/*
{{- end }}

COPY init.sh /etc/sandbox-persistent.sh
RUN chmod +x /etc/sandbox-persistent.sh
{{ if and .InstallPlugins .PluginRepos }}
# Claude Code plugins from kennel config
RUN mkdir -p /opt/plugins && \
{{- $last := sub (len .PluginRepos) 1 -}}
{{- range $i, $p := .PluginRepos }}
    git clone --depth 1 {{$p.URL}} /opt/plugins/{{$p.Path}}{{ if ne $i $last }} && \{{ end }}
{{- end }}
{{- end }}
{{ if .DockerfileExtra }}
# Begin dockerfile_extra: {{.DockerfileExtraPath}}
{{.DockerfileExtra}}
# End dockerfile_extra
{{ end }}
USER agent
RUN case "${AGENT}" in \
        claude) mkdir -p ~/.claude ;; \
        codex)  mkdir -p ~/.codex ;; \
        *)      mkdir -p "$HOME/.${AGENT}" ;; \
    esac
